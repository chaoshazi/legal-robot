# App
APP_NAME=legal-consult-bot
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# Database
POSTGRES_USER=legalbot
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=legalbot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=legal_docs

# Ollama (local embedding models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=mxbai-embed-large
# Available: mxbai-embed-large (best), nomic-embed-text (balanced), all-minilm:l6-v2 (lightweight)

# LangSmith
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=legal-consult-bot
LANGSMITH_TRACING=true

# Sentry
SENTRY_DSN=

# Admin seed password (used by scripts/seed.py)
ADMIN_PASSWORD=admin123456
