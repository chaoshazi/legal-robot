{
  "title": "法律咨询机器人 - 业务总览",
  "uid": "legal-bot-overview",
  "description": "法律咨询机器人整体监控仪表板 - API、咨询单、Agent 执行、系统状态",
  "tags": ["legal-bot", "production"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "ds_prometheus",
        "type": "datasource",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "API 总览",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "title": "QPS",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "rate(legal_bot_requests_total[5m])",
          "legendFormat": "总请求"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "title": "错误率",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "targets": [
        {
          "expr": "rate(legal_bot_errors_total[5m]) / (rate(legal_bot_requests_total[5m]) + 1) * 100",
          "legendFormat": "错误率"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "title": "P95 延迟",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "title": "总错误数",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "targets": [
        {
          "expr": "increase(legal_bot_errors_total[24h])",
          "legendFormat": "24h 错误"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 50}
            ]
          }
        }
      }
    },
    {
      "title": "工具调用次数",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "targets": [
        {
          "expr": "increase(legal_bot_tool_calls_total[24h])",
          "legendFormat": "工具调用"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "palette-classic"}}
      }
    },
    {
      "title": "缓存命中率",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "targets": [
        {
          "expr": "rate(legal_bot_cache_hits_total[5m]) / (rate(legal_bot_cache_hits_total[5m]) + rate(legal_bot_cache_misses_total[5m]) + 1) * 100",
          "legendFormat": "缓存命中率"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 30},
              {"color": "green", "value": 70}
            ]
          }
        }
      }
    },

    {
      "title": "请求与延迟趋势",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false
    },
    {
      "title": "QPS 趋势",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "rate(legal_bot_requests_total[1m])",
          "legendFormat": "QPS"
        },
        {
          "expr": "rate(legal_bot_errors_total[1m])",
          "legendFormat": "错误"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "P50 / P95 / P99 延迟",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": {"mode": "palette-classic"}
        }
      }
    },

    {
      "title": "Agent 与缓存分析",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "collapsed": false
    },
    {
      "title": "工具调用分布",
      "type": "piechart",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 15},
      "targets": [
        {
          "expr": "increase(legal_bot_tool_calls_total[24h])",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["value", "percent"]},
        "pieType": "pie",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "palette-classic"}}
      }
    },
    {
      "title": "缓存命中 vs 未命中",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 15},
      "targets": [
        {
          "expr": "rate(legal_bot_cache_hits_total[5m])",
          "legendFormat": "命中"
        },
        {
          "expr": "rate(legal_bot_cache_misses_total[5m])",
          "legendFormat": "未命中"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "缓存条目数",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 8, "w": 4, "x": 16, "y": 15},
      "targets": [
        {
          "expr": "legal_bot_cache_size",
          "legendFormat": "缓存条目"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "错误分类（按 error_type）",
      "type": "barchart",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 8, "w": 4, "x": 20, "y": 15},
      "targets": [
        {
          "expr": "increase(legal_bot_errors_total[1h])",
          "legendFormat": "{{error_type}}"
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"}
        }
      }
    },

    {
      "title": "系统状态",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "collapsed": false
    },
    {
      "title": "Backend 探活",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "up{job=\"backend\"}",
          "legendFormat": "up"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "title": "审计日志清理状态",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 24},
      "targets": [
        {
          "expr": "increase(legal_bot_audit_log_cleanup_total{status=\"success\"}[24h])",
          "legendFormat": "成功"
        },
        {
          "expr": "increase(legal_bot_audit_log_cleanup_total{status=\"error\"}[24h])",
          "legendFormat": "失败"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "title": "LLM Token 消耗",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${ds_prometheus}"},
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 24},
      "targets": [
        {
          "expr": "rate(legal_bot_llm_tokens_total{type=\"prompt\"}[5m])",
          "legendFormat": "Prompt tokens - {{model}}"
        },
        {
          "expr": "rate(legal_bot_llm_tokens_total{type=\"completion\"}[5m])",
          "legendFormat": "Completion tokens - {{model}}"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"}
        }
      }
    }
  ]
}
